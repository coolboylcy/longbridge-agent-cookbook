# ── Longbridge OpenAPI (headless / SDK path) ──────────────────────────────────
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
TRADING_MODE=paper
WATCHLIST=AAPL.US,NVDA.US,TSLA.US,700.HK,9988.HK

# ── Supabase (shared across all apps) ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_HUB_URL=https://longbridge-cookbook.vercel.app
